# Gmail SMTP — use a Gmail App Password (NOT your real Gmail password)
# Guide: https://support.google.com/accounts/answer/185833
GMAIL_USER=youremail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Your deployed Vercel app URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://ux-event-digest.vercel.app

# Random secret to protect the /api/cron endpoint
# Generate one: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# Vercel Postgres — auto-filled by Vercel when you add the database
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Optional: Google Custom Search (100 free queries/day) for better event discovery
# Get at: https://developers.google.com/custom-search/v1/introduction
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
